<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SimConfig - Monotonic Load Cell Setup" Height="850" Width="1200"
        Background="#121212" Foreground="White" WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="8" Padding="15" Margin="5">
            <StackPanel>
                <TextBlock Text="CONEXÃO" FontSize="14" FontWeight="Bold" Foreground="#007ACC" Margin="0,0,0,10"/>
                <ComboBox x:Name="ComboPorts" Height="30" Margin="0,5,0,10" 
                          Background="#E0E0E0" Foreground="Black" BorderBrush="#555" DropDownOpened="apertouComboBox">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Background" Value="#F0F0F0"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#007ACC"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>
                <Button x:Name="ButtonConnect" Content="CONECTAR" Click="ButtonConnect_Click" Height="35" Background="#007ACC" Foreground="White" FontWeight="Bold"/>

                <Separator Background="#333" Margin="0,20"/>

                <TextBlock Text="EFEITOS (FREIO)" FontSize="14" FontWeight="Bold" Foreground="#DC3545" Margin="0,0,0,10"/>
                <CheckBox x:Name="ChkAbs" Content="Ativar ABS" IsChecked="True" Foreground="White" Margin="0,5"/>
                <TextBlock Text="Intensidade:" FontSize="11" Margin="0,5"/>
                <Slider x:Name="SldInt" Minimum="0" Maximum="100" Value="50" Margin="0,5"/>

                <Button Content="SALVAR" Margin="0,40,0,0" Height="45" Background="#28A745" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- ÁREA DOS PEDAIS -->
        <UniformGrid Grid.Column="1" Columns="2" Rows="2">
            <ContentControl x:Name="CtrlAccel" Tag="ACELERADOR" Margin="25"/>
            <ContentControl x:Name="CtrlBrake" Tag="FREIO" Margin="25"/>
            <ContentControl x:Name="CtrlClutch" Tag="EMBREAGEM" Margin="25"/>
            <ContentControl x:Name="CtrlHand" Tag="FREIO DE Mão" Margin="25"/>
        </UniformGrid>
    </Grid>
</Window>