<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SimConfig - Telemetria Load Cell" Height="950" Width="1200"
        Background="#121212" Foreground="White" WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Indicadores Circulares -->
            <RowDefinition Height="*"/>
            <!-- Gráficos -->
            <RowDefinition Height="180"/>
            <!-- Terminal Serial -->
        </Grid.RowDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Background="#1E1E1E" CornerRadius="8" Padding="15" Margin="5">
            <StackPanel>
                <TextBlock Text="CONEXÃO" FontSize="14" FontWeight="Bold" Foreground="#007ACC" Margin="0,0,0,10"/>
                <ComboBox x:Name="ComboPorts" Height="30" Margin="0,5,0,10" Background="#E0E0E0" Foreground="Black" DropDownOpened="apertouComboBox"/>
                <Button x:Name="ButtonConnect" Content="CONECTAR" Click="ButtonConnect_Click" Height="35" Background="#007ACC" Foreground="White" FontWeight="Bold"/>

                <Separator Background="#333" Margin="0,20"/>

                <TextBlock Text="CONFIGURAÇÃO" FontSize="14" FontWeight="Bold" Foreground="#FFC107" Margin="0,0,0,10"/>
                <CheckBox x:Name="ChkAbs" Content="Ativar ABS" IsChecked="True" Foreground="White" Margin="0,5"/>

                <TextBlock Text="Força Teste:" FontSize="11" Margin="0,10,0,5"/>
                <TextBox x:Name="TxtForce" Text="100" Background="#2D2D2D" Foreground="White" Height="25" VerticalContentAlignment="Center" Padding="5,0"/>

                <TextBlock Text="Distância Teste:" FontSize="11" Margin="0,5"/>
                <TextBox x:Name="TxtDistance" Text="100" Background="#2D2D2D" Foreground="White" Height="25" VerticalContentAlignment="Center" Padding="5,0"/>

                <Button Content="ENVIAR COMANDO" Click="ButtonSendData_Click" Margin="0,15,0,0" Height="30" Background="#6F42C1" Foreground="White" FontWeight="Bold"/>
                <Button Content="SALVAR NO DISPOSITIVO" Margin="0,30,0,0" Height="45" Background="#28A745" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- INDICADORES CIRCULARES (TELEMETRIA EM TEMPO REAL) -->
        <Border Grid.Row="0" Grid.Column="1" Background="#1A1A1A" CornerRadius="8" Margin="5" Padding="15">
            <UniformGrid Columns="4">
                <!-- Acelerador -->
                <StackPanel>
                    <Grid Height="100" Width="100">
                        <Ellipse Stroke="#333" StrokeThickness="8"/>
                        <Ellipse x:Name="EllAccel" Stroke="Green" StrokeThickness="8" Opacity="0.2"/>
                        <TextBlock x:Name="TxtAccelPerc" Text="0%" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" FontWeight="Bold"/>
                    </Grid>
                    <TextBlock Text="ACELERADOR" Foreground="Green" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,5"/>
                </StackPanel>

                <!-- Freio -->
                <StackPanel>
                    <Grid Height="100" Width="100">
                        <Ellipse Stroke="#333" StrokeThickness="8"/>
                        <Ellipse x:Name="EllBrake" Stroke="Red" StrokeThickness="8" Opacity="0.2"/>
                        <TextBlock x:Name="TxtBrakePerc" Text="0%" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" FontWeight="Bold"/>
                    </Grid>
                    <TextBlock Text="FREIO" Foreground="Red" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,5"/>
                </StackPanel>

                <!-- Embreagem -->
                <StackPanel>
                    <Grid Height="100" Width="100">
                        <Ellipse Stroke="#333" StrokeThickness="8"/>
                        <Ellipse x:Name="EllClutch" Stroke="Orange" StrokeThickness="8" Opacity="0.2"/>
                        <TextBlock x:Name="TxtClutchPerc" Text="0%" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" FontWeight="Bold"/>
                    </Grid>
                    <TextBlock Text="EMBREAGEM" Foreground="Orange" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,5"/>
                </StackPanel>

                <!-- Freio de Mão -->
                <StackPanel>
                    <Grid Height="100" Width="100">
                        <Ellipse Stroke="#333" StrokeThickness="8"/>
                        <Ellipse x:Name="EllHand" Stroke="Cyan" StrokeThickness="8" Opacity="0.2"/>
                        <TextBlock x:Name="TxtHandPerc" Text="0%" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" FontWeight="Bold"/>
                    </Grid>
                    <TextBlock Text="FREIO DE MÃO" Foreground="Cyan" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,5"/>
                </StackPanel>
            </UniformGrid>
        </Border>

        <!-- GRÁFICOS (CURVAS) -->
        <UniformGrid Grid.Row="1" Grid.Column="1" Columns="2" Rows="2">
            <ContentControl x:Name="CtrlAccel" Tag="ACELERADOR" Margin="15"/>
            <ContentControl x:Name="CtrlBrake" Tag="FREIO" Margin="15"/>
            <ContentControl x:Name="CtrlClutch" Tag="EMBREAGEM" Margin="15"/>
            <ContentControl x:Name="CtrlHand" Tag="FREIO DE MÃO" Margin="15"/>
        </UniformGrid>

        <!-- TERMINAL SERIAL -->
        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Background="#0A0A0A" CornerRadius="8" Margin="5" BorderBrush="#333" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="CONSOLE SERIAL" FontSize="10" Foreground="Gray" Margin="10,5,0,0"/>
                <TextBox x:Name="TxtSerialLog" Grid.Row="1" Background="Transparent" Foreground="#00FF00" 
                         BorderThickness="0" FontFamily="Consolas" IsReadOnly="True" 
                         VerticalScrollBarVisibility="Auto" Margin="10" TextWrapping="Wrap"/>
            </Grid>
        </Border>
    </Grid>
</Window>