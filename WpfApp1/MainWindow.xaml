<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SimConfig - Telemetria Load Cell"
        Height="950" Width="1250"
        Background="#0A0A0A"
        Foreground="White"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Semibold">

    <!-- 🎨 STYLES GLOBAIS -->
    <Window.Resources>

        <Style TargetType="Ellipse">
            <Setter Property="StrokeThickness" Value="10"/>
        </Style>

        <Style TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="#252525"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </Window.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#141414" Padding="20">

            <DockPanel>

                <StackPanel DockPanel.Dock="Top">

                    <TextBlock Text="HARDWARE" FontSize="10" Foreground="#777"/>
                    <TextBlock Text="CONEXÃO SERIAL" FontSize="16" Foreground="#FF1744" Margin="0,0,0,15"/>

                    <ComboBox x:Name="ComboPorts" Height="35"
                              Background="#1E1E1E" Foreground="#000000"
                              BorderThickness="0"
                              DropDownOpened="apertouComboBox"/>

                    <Button x:Name="ButtonConnect" Content="CONECTAR"
                            Background="#FF1744"
                            Height="40"
                            Margin="0,10"
                            Click="ButtonConnect_Click"/>

                    <Separator Margin="0,20"/>

                    <TextBlock Text="CALIBRAÇÃO" FontSize="10" Foreground="#777"/>

                    <CheckBox x:Name="ChkAbs" Foreground="White" Content="ABS ATIVO" Margin="0,10"/>

                    <!-- FORCE -->
                    <TextBlock Text="FORÇA (kg)" Margin="0,10,0,5"/>

                    <StackPanel>
                        <Slider x:Name="SliderForce"
                                Minimum="0" Maximum="200" Value="100"
                                Foreground="#FF1744"/>
                        <TextBlock Text="{Binding ElementName=SliderForce, Path=Value, StringFormat=F0}"
                                   HorizontalAlignment="Right"/>
                    </StackPanel>

                    <!-- DISTANCE -->
                    <TextBlock Text="DISTÂNCIA (mm)" Margin="0,10,0,5"/>

                    <StackPanel>
                        <Slider x:Name="SliderDistance"
                                Minimum="0" Maximum="200" Value="100"
                                Foreground="#FF1744"/>
                        <TextBlock Text="{Binding ElementName=SliderDistance, Path=Value, StringFormat=F0}"
                                   HorizontalAlignment="Right"/>
                    </StackPanel>

                    <Button Content="ATUALIZAR"
                            Margin="0,15,0,0"
                            Background="#1E1E1E"
                            BorderBrush="#FF1744"
                            BorderThickness="1"
                            Click="ButtonSendData_Click"/>
                    <Button Content="RECUPERAR CONFIGURAÇÕES"
                    Margin="0,15,0,0"
                    Background="#1E1E1E"
                    BorderBrush="#FF1744"
                    BorderThickness="1"
                    Click="ButtonRecover_Click"/>

                </StackPanel>


            </DockPanel>
        </Border>

        <!-- DASHBOARD -->
        <Grid Grid.Column="1" Margin="15,0,0,0">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="220"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="150"/>
            </Grid.RowDefinitions>

            <!-- STATUS -->
            <UniformGrid Columns="3" Margin="0,0,0,15">

                <Border Background="#141414" Padding="15">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="FORÇA:" Foreground="#777"/>
                        <TextBlock x:Name="TxtCurrForce" Text="0.0" FontSize="24" Margin="10,0"/>
                        <TextBlock Text="kg" Foreground="#555"/>
                    </StackPanel>
                </Border>

                <Border Background="#141414" Padding="15">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="DISTANCIA:" Foreground="#777"/>
                        <TextBlock x:Name="TxtCurrDistance" Text="0.0" FontSize="24" Margin="10,0"/>
                        <TextBlock Text="mm" Foreground="#555"/>
                    </StackPanel>
                </Border>

                <Border Background="#141414" Padding="15">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="ABS:" Foreground="#777"/>
                        <TextBlock x:Name="TxtAbsStatus" Text="OFF" FontSize="24" Foreground="#FF1744" Margin="10,0"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- GAUGES -->
            <Border Grid.Row="1" Background="#141414">

                <UniformGrid Columns="4">

                    <!-- ACCEL -->
                    <Grid>
                        <Ellipse Stroke="#222"/>
                        <Ellipse x:Name="EllAccel" Stroke="#FF1744" Opacity="0.5"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="TxtAccelPerc" Text="0%" FontSize="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="ACCEL" FontSize="10" Foreground="#777" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- BRAKE -->
                    <Grid>
                        <Ellipse Stroke="#222"/>
                        <Ellipse x:Name="EllBrake" Stroke="#FF1744" Opacity="0.5"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="TxtBrakePerc" Text="0%" FontSize="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="BRAKE" FontSize="10" Foreground="#777" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- CLUTCH -->
                    <Grid>
                        <Ellipse Stroke="#222"/>
                        <Ellipse x:Name="EllClutch" Stroke="#FF1744" Opacity="0.5"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="TxtClutchPerc" Text="0%" FontSize="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="CLUTCH" FontSize="10" Foreground="#777" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- HAND -->
                    <Grid>
                        <Ellipse Stroke="#222"/>
                        <Ellipse x:Name="EllHand" Stroke="#FF1744" Opacity="0.5"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="TxtHandPerc" Text="0%" FontSize="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="HAND" FontSize="10" Foreground="#777" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                </UniformGrid>

            </Border>

            <!-- GRÁFICOS -->
            <UniformGrid Grid.Row="2" Columns="2" Rows="2" Margin="0,15">

                <Border Background="#121212" Margin="5">
                    <ContentControl x:Name="CtrlAccel"/>
                </Border>

                <Border Background="#121212" Margin="5">
                    <ContentControl x:Name="CtrlBrake"/>
                </Border>

                <Border Background="#121212" Margin="5">
                    <ContentControl x:Name="CtrlClutch"/>
                </Border>

                <Border Background="#121212" Margin="5">
                    <ContentControl x:Name="CtrlHand"/>
                </Border>

            </UniformGrid>

            <!-- SERIAL -->
            <Border Grid.Row="3" Background="#050505">
                <TextBox x:Name="TxtSerialLog"
                         Background="Transparent"
                         Foreground="#FF1744"
                         FontFamily="Consolas"
                         BorderThickness="0"
                         Margin="10"
                         IsReadOnly="True"/>
            </Border>

        </Grid>
    </Grid>
</Window>