<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SimConfig - Monotonic Load Cell Setup" Height="950" Width="1200"
        Background="#121212" Foreground="White" WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="180"/>
            <!-- Área para o Serial Log -->
        </Grid.RowDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Row="0" Grid.Column="0" Background="#1E1E1E" CornerRadius="8" Padding="15" Margin="5">
            <StackPanel>
                <TextBlock Text="CONEXÃO" FontSize="14" FontWeight="Bold" Foreground="#007ACC" Margin="0,0,0,10"/>
                <ComboBox x:Name="ComboPorts" Height="30" Margin="0,5,0,10" 
                          Background="#E0E0E0" Foreground="Black" BorderBrush="#555" DropDownOpened="apertouComboBox"/>
                <Button x:Name="ButtonConnect" Content="CONECTAR" Click="ButtonConnect_Click" Height="35" Background="#007ACC" Foreground="White" FontWeight="Bold"/>

                <Separator Background="#333" Margin="0,20"/>

                <TextBlock Text="EFEITOS (FREIO)" FontSize="14" FontWeight="Bold" Foreground="#DC3545" Margin="0,0,0,10"/>
                <CheckBox x:Name="ChkAbs" Content="Ativar ABS" IsChecked="True" Foreground="White" Margin="0,5"/>
                <TextBlock Text="Intensidade:" FontSize="11" Margin="0,5"/>
                <Slider x:Name="SldInt" Minimum="0" Maximum="100" Value="50" Margin="0,5"/>

                <Separator Background="#333" Margin="0,20"/>

                <!-- NOVO: Nível de Felicidade -->
                <TextBlock Text="CONFIGURAÇÃO EXTRA" FontSize="14" FontWeight="Bold" Foreground="#FFC107" Margin="0,0,0,10"/>
                <TextBlock Text="Digite a força:" FontSize="11" Margin="0,5"/>
                <TextBox x:Name="TxtForce" Text="100" Background="#2D2D2D" Foreground="White" BorderBrush="#555" Height="25" VerticalContentAlignment="Center" Padding="5,0"/>
                <TextBlock Text="Digite uma distancia:" FontSize="11" Margin="0,5"/>
                <TextBox x:Name="TxtDistance" Text="100" Background="#2D2D2D" Foreground="White" BorderBrush="#555" Height="25" VerticalContentAlignment="Center" Padding="5,0"/>
                <Button Content="ENVIAR DADOS" Click="ButtonSendData_Click"  Margin="0,10,0,0" Height="30" Background="#6F42C1" Foreground="White" FontWeight="Bold"/>

                <Button Content="SALVAR TUDO" Margin="0,30,0,0" Height="45" Background="#28A745" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- ÁREA DOS PEDAIS -->
        <UniformGrid Grid.Row="0" Grid.Column="1" Columns="2" Rows="2">
            <ContentControl x:Name="CtrlAccel" Tag="ACELERADOR" Margin="25"/>
            <ContentControl x:Name="CtrlBrake" Tag="FREIO" Margin="25"/>
            <ContentControl x:Name="CtrlClutch" Tag="EMBREAGEM" Margin="25"/>
            <ContentControl x:Name="CtrlHand" Tag="FREIO DE Mão" Margin="25"/>
        </UniformGrid>

        <!-- NOVO: TERMINAL SERIAL -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Background="#0A0A0A" CornerRadius="8" Margin="5" BorderBrush="#333" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="MONITOR SERIAL" FontSize="10" Foreground="Gray" Margin="10,5,0,0"/>
                <TextBox x:Name="TxtSerialLog" Grid.Row="1" Background="Transparent" Foreground="#00FF00" 
                         BorderThickness="0" FontFamily="Consolas" IsReadOnly="True" 
                         VerticalScrollBarVisibility="Auto" Margin="10" TextWrapping="Wrap"/>
            </Grid>
        </Border>
    </Grid>
</Window>